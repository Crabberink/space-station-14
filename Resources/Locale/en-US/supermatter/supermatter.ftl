# Warning message when damage is being taken, and integrity is between 95% and 40%
supermatter-integrity-message-warning = Danger! Crystal hyperstructure integrity faltering! Integrity: {$integrity}%

# Warning message when damage is being taken, and integrity is between 15% and 0%
supermatter-integrity-message-emergency = CRYSTAL DELAMINATION IMMINENT! Integrity: {$integrity}%

# Warning message when damage is being healed
supermatter-integrity-message-healing = Crystalline hyperstructure returning to safe operating parameters. Integrity: {$integrity}%